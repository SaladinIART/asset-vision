# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Data (local only — never commit)
data/
*.db
*.sqlite3

# Model weights (large, auto-downloaded)
*.pt
*.onnx
*.xml
*.bin
# …but DO keep ROS2 package manifests (colcon needs them to build)
!**/package.xml

# Captured frames / thumbnails (runtime output — do not commit)
frames/
snapshots/
data/frames/
*.jpg
*.png
# …but keep intentional assets
!web/static/**/*.png
!docs/**/*.png
!samples/*.jpg
!samples/*.png

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE / local tooling (personal, machine-specific)
.vscode/
.idea/
*.swp
