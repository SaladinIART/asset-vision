# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Data (local only — never commit)
data/
*.db
*.sqlite3

# Model weights (large, auto-downloaded)
*.pt
*.onnx
*.xml
*.bin
