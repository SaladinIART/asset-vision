!**/package.xml

# Captured frames / thumbnails
frames/
snapshots/
*.jpg
*.png
!web/static/**/*.png
!docs/**/*.png

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE / local tooling (personal, machine-specific)
.vscode/
.idea/
.claude/
*.swp
